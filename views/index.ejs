    <div class="card">
      <h3>已注册客户端列表</h3>
      <div style="margin-bottom:10px">
        <button class="btn btn-outline btn-sm" onclick="refreshClients()">刷新</button>
      </div>
      <div id="cm-list" style="display:flex;flex-direction:column;gap:10px">
      </div>
    </div>
  </div>
</div>

<!-- ========== 授权记录 ========== -->
<div class="panel" id="panel-grants">
  <div class="card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <h3 style="margin-bottom:0">用户 → 客户端 授权记录</h3>
      <button class="btn btn-outline btn-sm" onclick="refreshGrants()">刷新</button>
    </div>
    <div class="info-box">每条记录表示一个用户给某个客户端授过哪些 scope。撤销授权会将该用户对该客户端的所有刷新令牌吊销，旧 refresh_token 将无法换取新 token。</div>
    <div id="grants-table-wrap" style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
          <tr style="background:#0f172a">
            <th style="padding:10px;border:1px solid #334155;text-align:left">用户</th>
            <th style="padding:10px;border:1px solid #334155;text-align:left">客户端</th>
            <th style="padding:10px;border:1px solid #334155;text-align:left">Scope</th>
            <th style="padding:10px;border:1px solid #334155;text-align:left">首次授权</th>
            <th style="padding:10px;border:1px solid #334155;text-align:left">授权次数</th>
            <th style="padding:10px;border:1px solid #334155;text-align:left">状态</th>
            <th style="padding:10px;border:1px solid #334155;text-align:left">操作</th>
          </tr>
        </thead>
        <tbody id="grants-tbody">
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
const ISSUER = '<%= issuer %>';
const TEST_CLIENTS = <%- JSON.stringify(testClients) %>;

document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    document.getElementById('panel-' + t.dataset.tab).classList.add('active');
  });
});

document.querySelectorAll('.scope-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const cb = chip.querySelector('input');
    cb.checked = !cb.checked;
    chip.classList.toggle('selected', cb.checked);
  });
});

let pkceVerifier = null;

function generateCodeVerifier() {
  const arr = new Uint8Array(32);
  crypto.getRandomValues(arr);
  return btoa(String.fromCharCode(...arr)).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');
}

async function generateCodeChallenge(verifier) {
  const enc = new TextEncoder().encode(verifier);
  const hash = await crypto.subtle.digest('SHA-256', enc);
  return btoa(String.fromCharCode(...new Uint8Array(hash))).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');
}

function onClientChange() {
  const sel = document.getElementById('ac-client');
  const opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value) return;
  const clientScope = opt.dataset.scope || '';
  const clientType = opt.dataset.type || '';
  document.querySelectorAll('#ac-scopes .scope-chip').forEach(chip => {
    const cb = chip.querySelector('input');
    const s = cb.value;
    const inScope = clientScope.split(/\s+/).includes(s);
    chip.style.opacity = inScope ? '1' : '0.4';
    cb.checked = inScope && (s === 'openid' || s === 'profile');
    chip.classList.toggle('selected', cb.checked);
  });
  if (clientType === 'public') {
    pkceVerifier = generateCodeVerifier();
    document.getElementById('ac-code-verifier').value = pkceVerifier;
  } else {
    pkceVerifier = null;
    document.getElementById('ac-code-verifier').value = '';
  }
}

function onCCClientChange() {
  const sel = document.getElementById('cc-client');
  const opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value) return;
  document.getElementById('cc-scope').value = opt.dataset.scope || '';
}

function onQuickClientChange() {
  const sel = document.getElementById('td-quick-client');
  const val = sel.value;
  if (val) {
    document.getElementById('td-introspect-client').value = val;
    document.getElementById('td-revoke-client').value = val;
    document.getElementById('td-refresh-client').value = val;
  }
}

function getSelectedScopes() {
  const scopes = [];
  document.querySelectorAll('#ac-scopes .scope-chip input:checked').forEach(cb => {
    scopes.push(cb.value);
  });
  return scopes.join(' ');
}

async function startAuthCode() {
  const sel = document.getElementById('ac-client');
  const opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value) { alert('请先选择客户端'); return; }

  const clientId = opt.value;
  const scope = getSelectedScopes();
  const state = document.getElementById('ac-state').value;
  const redirectUri = document.getElementById('ac-redirect-uri').value;

  let url = `${ISSUER}/authorize?response_type=code&client_id=${encodeURIComponent(clientId)}&redirect_uri=${encodeURIComponent(redirectUri)}&scope=${encodeURIComponent(scope)}&state=${encodeURIComponent(state)}`;

  if (pkceVerifier) {
    const challenge = await generateCodeChallenge(pkceVerifier);
    url += `&code_challenge=${encodeURIComponent(challenge)}&code_challenge_method=S256`;
  }

  document.getElementById('step1').classList.add('done');
  document.getElementById('step2').classList.add('current');
  document.getElementById('ac-code-info').style.display = 'block';
  document.getElementById('ac-code-info').textContent = '正在跳转到授权页面，请登录并确认授权...';

  window.open(url, '_blank');
}

async function exchangeCode() {
  const code = document.getElementById('ac-code').value.trim();
  if (!code) { alert('请输入授权码'); return; }

  const sel = document.getElementById('ac-client');
  const opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value) { alert('请先选择客户端'); return; }

  const clientId = opt.value;
  const clientSecret = opt.dataset.secret || '';
  const redirectUri = document.getElementById('ac-redirect-uri').value;
  const codeVerifier = document.getElementById('ac-code-verifier').value;

  const body = new URLSearchParams({
    grant_type: 'authorization_code',
    code: code,
    redirect_uri: redirectUri,
  });
  if (codeVerifier) body.set('code_verifier', codeVerifier);

  const headers = { 'Content-Type': 'application/x-www-form-urlencoded' };
  if (clientSecret) {
    headers['Authorization'] = 'Basic ' + btoa(clientId + ':' + clientSecret);
  } else {
    body.set('client_id', clientId);
  }

  try {
    const res = await fetch(`${ISSUER}/token`, { method: 'POST', headers, body });
    const data = await res.json();

    if (data.error) {
      document.getElementById('ac-result-card').style.display = 'block';
      document.getElementById('ac-token-results').innerHTML =
        `<div class="result-box" style="color:var(--error)">${JSON.stringify(data, null, 2)}</div>`;
      return;
    }

    document.getElementById('step1').classList.add('done');
    document.getElementById('step2').classList.add('done');
    document.getElementById('step3').classList.add('current');
    document.getElementById('ac-result-card').style.display = 'block';

    let html = '';
    if (data.access_token) {
      html += buildTokenDisplay('Access Token', data.access_token);
      fillTokenDebug('introspect', data.access_token, clientId + ':' + clientSecret);
    }
    if (data.refresh_token) {
      html += buildTokenDisplay('Refresh Token', data.refresh_token, 'refresh_token');
      fillTokenDebug('revoke', data.refresh_token, clientId + ':' + clientSecret);
      document.getElementById('td-refresh-token').value = data.refresh_token;
      document.getElementById('td-refresh-client').value = clientId + ':' + clientSecret;
    }
    if (data.id_token) {
      html += buildTokenDisplay('ID Token', data.id_token, 'id_token');
    }
    html += `<div class="result-box" style="margin-top:12px">${syntaxHighlight(JSON.stringify(data, null, 2))}</div>`;
    document.getElementById('ac-token-results').innerHTML = html;
  } catch (e) {
    alert('请求失败: ' + e.message);
  }
}

function buildTokenDisplay(label, value, hint) {
  const id = 'tok-' + Math.random().toString(36).substring(2,8);
  return `<div class="token-display">
    <div class="token-label">${label} ${hint ? '(' + hint + ')' : ''}</div>
    <div class="token-value" id="${id}">${value}</div>
    <button class="copy-btn" onclick="copyToken('${id}')">复制</button>
  </div>`;
}

function copyToken(id) {
  const el = document.getElementById(id);
  if (el) {
    navigator.clipboard.writeText(el.textContent).then(() => {
      const btn = el.parentElement.querySelector('.copy-btn');
      btn.textContent = '已复制!';
      setTimeout(() => btn.textContent = '复制', 1500);
    });
  }
}

function fillTokenDebug(type, token, clientAuth) {
  if (type === 'introspect') {
    document.getElementById('td-introspect-token').value = token;
    document.getElementById('td-introspect-client').value = clientAuth;
  }
  document.getElementById('td-revoke-token').value = token;
  document.getElementById('td-revoke-client').value = clientAuth;
}

async function getClientCredentials() {
  const sel = document.getElementById('cc-client');
  const opt = sel.options[sel.selectedIndex];
  if (!opt || !opt.value) { alert('请选择客户端'); return; }

  const clientId = opt.value;
  const clientSecret = opt.dataset.secret || '';
  const scope = document.getElementById('cc-scope').value.trim();

  const body = new URLSearchParams({ grant_type: 'client_credentials' });
  if (scope) body.set('scope', scope);

  const headers = { 'Content-Type': 'application/x-www-form-urlencoded' };
  headers['Authorization'] = 'Basic ' + btoa(clientId + ':' + clientSecret);

  try {
    const res = await fetch(`${ISSUER}/token`, { method: 'POST', headers, body });
    const data = await res.json();
    document.getElementById('cc-result').innerHTML = syntaxHighlight(JSON.stringify(data, null, 2));

    if (data.access_token) {
      fillTokenDebug('introspect', data.access_token, clientId + ':' + clientSecret);
      document.getElementById('td-revoke-token').value = data.access_token;
      document.getElementById('td-revoke-client').value = clientId + ':' + clientSecret;
    }
  } catch (e) {
    document.getElementById('cc-result').textContent = '请求失败: ' + e.message;
  }
}

async function introspectToken() {
  const token = document.getElementById('td-introspect-token').value.trim();
  if (!token) { alert('请输入 Token'); return; }

  const clientAuth = document.getElementById('td-introspect-client').value.trim();
  const hint = document.getElementById('td-introspect-hint').value;

  const body = new URLSearchParams({ token });
  if (hint) body.set('token_type_hint', hint);

  const headers = { 'Content-Type': 'application/x-www-form-urlencoded' };
  if (clientAuth) {
    const [id, secret] = clientAuth.split(':');
    headers['Authorization'] = 'Basic ' + btoa(id + ':' + (secret || ''));
  }

  try {
    const res = await fetch(`${ISSUER}/introspect`, { method: 'POST', headers, body });
    const data = await res.json();
    const statusBadge = data.active
      ? '<span class="status-badge status-active">● ACTIVE</span>'
      : '<span class="status-badge status-inactive">● INACTIVE</span>';
    document.getElementById('td-introspect-result').innerHTML =
      statusBadge + '\n' + syntaxHighlight(JSON.stringify(data, null, 2));
  } catch (e) {
    document.getElementById('td-introspect-result').textContent = '请求失败: ' + e.message;
  }
}

async function revokeToken() {
  const token = document.getElementById('td-revoke-token').value.trim();
  if (!token) { alert('请输入 Token'); return; }

  const clientAuth = document.getElementById('td-revoke-client').value.trim();
  const hint = document.getElementById('td-revoke-hint').value;

  const body = new URLSearchParams({ token });
  if (hint) body.set('token_type_hint', hint);

  const headers = { 'Content-Type': 'application/x-www-form-urlencoded' };
  if (clientAuth) {
    const [id, secret] = clientAuth.split(':');
    headers['Authorization'] = 'Basic ' + btoa(id + ':' + (secret || ''));
  }

  try {
    const res = await fetch(`${ISSUER}/revoke`, { method: 'POST', headers, body });
    if (res.status === 200) {
      document.getElementById('td-revoke-result').innerHTML =
        '<span class="status-badge status-inactive">● REVOKED</span>\n令牌已成功撤销。再次内省将显示 active: false';
    } else {
      const data = await res.json();
      document.getElementById('td-revoke-result').innerHTML = syntaxHighlight(JSON.stringify(data, null, 2));
    }
  } catch (e) {
    document.getElementById('td-revoke-result').textContent = '请求失败: ' + e.message;
  }
}

async function refreshToken() {
  const rt = document.getElementById('td-refresh-token').value.trim();
  if (!rt) { alert('请输入 Refresh Token'); return; }

  const clientAuth = document.getElementById('td-refresh-client').value.trim();
  const scope = document.getElementById('td-refresh-scope').value.trim();

  const body = new URLSearchParams({ grant_type: 'refresh_token', refresh_token: rt });
  if (scope) body.set('scope', scope);

  const headers = { 'Content-Type': 'application/x-www-form-urlencoded' };
  if (clientAuth) {
    const [id, secret] = clientAuth.split(':');
    headers['Authorization'] = 'Basic ' + btoa(id + ':' + (secret || ''));
  }

  try {
    const res = await fetch(`${ISSUER}/token`, { method: 'POST', headers, body });
    const data = await res.json();
    let output = syntaxHighlight(JSON.stringify(data, null, 2));
    if (data.refresh_token) {
      output = '<div class="info-box">刷新令牌已轮换！旧 refresh_token 不再有效，请使用新的 refresh_token。</div>' + output;
      document.getElementById('td-refresh-token').value = data.refresh_token;
    }
    if (data.access_token) {
      document.getElementById('td-introspect-token').value = data.access_token;
    }
    document.getElementById('td-refresh-result').innerHTML = output;
  } catch (e) {
    document.getElementById('td-refresh-result').textContent = '请求失败: ' + e.message;
  }
}

async function loadDiscovery() {
  try {
    const res = await fetch(`${ISSUER}/.well-known/openid-configuration`);
    const data = await res.json();
    document.getElementById('discovery-result').innerHTML = syntaxHighlight(JSON.stringify(data, null, 2));
  } catch (e) {
    document.getElementById('discovery-result').textContent = '请求失败: ' + e.message;
  }
}

async function loadJWKS() {
  try {
    const res = await fetch(`${ISSUER}/.well-known/jwks.json`);
    const data = await res.json();
    document.getElementById('jwks-result').innerHTML = syntaxHighlight(JSON.stringify(data, null, 2));
  } catch (e) {
    document.getElementById('jwks-result').textContent = '请求失败: ' + e.message;
  }
}

function syntaxHighlight(json) {
  return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function(match) {
    let cls = 'color:#fb923c';
    if (/^"/.test(match)) {
      if (/:$/.test(match)) {
        cls = 'color:#c084fc';
      } else {
        cls = 'color:#4ade80';
      }
    } else if (/true|false/.test(match)) {
      cls = 'color:#60a5fa';
    } else if (/null/.test(match)) {
      cls = 'color:#64748b';
    }
    return '<span style="' + cls + '">' + match + '</span>';
  });
}

const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('code')) {
  document.getElementById('ac-code').value = urlParams.get('code');
}

function callUserinfo() {
  const token = document.getElementById('ui-token').value.trim();
  if (!token) { alert('请先粘贴 access_token'); return; }
  fetch(ISSUER + '/userinfo', {
    headers: { Authorization: 'Bearer ' + token },
  })
    .then((r) => r.json().then((data) => ({ status: r.status, data })))
    .then(({ status, data }) => {
      const keys = Object.keys(data).join(', ');
      document.getElementById('ui-result').innerHTML =
        `<div>HTTP ${status} &nbsp; | &nbsp; Claims: <code style="color:#4ade80">${keys}</code></div>\n` +
        syntaxHighlight(JSON.stringify(data, null, 2));
    })
    .catch((e) => {
      document.getElementById('ui-result').textContent = '请求失败: ' + e.message;
    });
}

function demoUserinfoScopes(scope) {
  const sel = document.getElementById('ac-client');
  let client = null;
  for (const opt of sel.options) {
    if (opt.value && opt.value && opt.dataset.type === 'confidential') {
      client = { id: opt.value, secret: opt.dataset.secret };
      break;
    }
  }
  if (!client) {
    const fallback = TEST_CLIENTS.find((c) => c.client_secret);
    if (!fallback) { document.getElementById('ui-demo-result').textContent = '找不到 confidential 客户端'; return; }
    client = { id: fallback.client_id, secret: fallback.client_secret };
  }
  const body = new URLSearchParams({
    grant_type: 'client_credentials',
    scope: scope,
  });
  const auth = 'Basic ' + btoa(client.id + ':' + client.clientSecret);
  fetch(ISSUER + '/token', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', Authorization: auth },
    body: body.toString(),
  })
    .then((r) => r.json().then((t) => ({ status: r.status, t })))
    .then(({ t }) => {
      if (!t.access_token) {
        document.getElementById('ui-demo-result').innerHTML =
          `<span style="color:var(--error)">获取 token 失败 (client_credentials 不会产生用户级 token，这里演示说明 scope 对 UserInfo 的影响需要走授权码流程获取带用户的 AT)。</span>\n` +
          syntaxHighlight(JSON.stringify(t, null, 2));
        return;
      }
      return fetch(ISSUER + '/userinfo', {
        headers: { Authorization: 'Bearer ' + t.access_token },
      })
        .then((r) => r.json())
        .then((u) => {
          const keys = Object.keys(u);
          document.getElementById('ui-demo-result').innerHTML =
            `<div>请求 Scope: <code style="color:#60a5fa">${scope}</code> &nbsp; | &nbsp; 返回 Claims: <code style="color:#4ade80">${keys.join(', ') || '(无)'}</code></div>\n` +
            syntaxHighlight(JSON.stringify(u, null, 2));
        });
    })
    .catch((e) => {
      document.getElementById('ui-demo-result').textContent = '请求失败: ' + e.message;
    });
}

function createClient() {
  const name = document.getElementById('cm-name').value.trim();
  const type = document.getElementById('cm-type').value;
  const grants = document.getElementById('cm-grants').value.trim().split(/\s+/).filter(Boolean);
  const responses = document.getElementById('cm-responses').value.trim().split(/\s+/).filter(Boolean);
  const scope = document.getElementById('cm-scope').value.trim();
  const redirectUris = document.getElementById('cm-redirects').value.split(/\n/).map((s) => s.trim()).filter(Boolean);

  if (!name) { alert('请填写客户端名称'); return; }

  fetch(ISSUER + '/api/clients', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      name,
      type,
      grant_types: grants,
      response_types: responses,
      scope: scope,
      redirect_uris: redirectUris,
    }),
  })
    .then((r) => r.json().then((d) => ({ status: r.status, d })))
    .then(({ status, d }) => {
      document.getElementById('cm-create-result').innerHTML =
        `<div>HTTP ${status}</div>\n` + syntaxHighlight(JSON.stringify(d, null, 2));
      if (status === 201) {
        refreshClients();
        alert('客户端创建成功！client_secret 只会在这里出现一次，请妥善保存。');
        refreshAllClientSelects().catch(()=>{});
      }
    })
    .catch((e) => {
      document.getElementById('cm-create-result').textContent = '请求失败: ' + e.message;
    });
}

function deleteClient(clientId) {
  if (!confirm('确认删除客户端 ' + clientId + ' ?')) return;
  fetch(ISSUER + '/api/clients/' + encodeURIComponent(clientId), { method: 'DELETE' })
    .then((r) => r.json())
    .then((d) => {
      alert(d.removed ? '已删除' : '删除失败');
      refreshClients();
      refreshAllClientSelects().catch(()=>{});
    });
}

function refreshClients() {
  fetch(ISSUER + '/api/clients')
    .then((r) => r.json())
    .then((d) => {
      const list = document.getElementById('cm-list');
      list.innerHTML = '';
      for (const c of d.test_clients) {
        const div = document.createElement('div');
        div.className = 'card';
        div.style.marginBottom = '0';
        div.style.padding = '14px';
        const auth = btoa((c.client_id || '') + ':' + (c.client_secret || ''));
        div.innerHTML =
          `<div style="font-weight:600;color:#fff;margin-bottom:6px">${c.name} <span style="font-weight:400;font-size:12px;color:#94a3b8">(<span style="color:${c.type==='confidential'?'#f59e0b':'#60a5fa'}">${c.type}</span>)</span></div>` +
          `<div style="font-size:12px;color:#94a3b8;margin-bottom:4px">client_id: <code style="color:#a5b4fc">${c.client_id}</code></div>` +
          (c.client_secret ? `<div style="font-size:12px;color:#94a3b8;margin-bottom:4px">client_secret: <code style="color:#4ade80">${c.client_secret}</code></div>` : '') +
          `<div style="font-size:12px;color:#94a3b8;margin-bottom:4px">grant_types: <code>${c.grant_types.join(' ')}</code></div>` +
          `<div style="font-size:12px;color:#94a3b8;margin-bottom:4px">scope: <code>${c.scope}</code></div>` +
          `<div style="font-size:12px;color:#94a3b8;margin-bottom:8px">redirect_uris: <code>${(c.redirect_uris||[]).join(', ') || '(无)'}</code></div>` +
          `<button class="btn btn-danger btn-sm" style="padding:4px 10px" onclick="deleteClient('${c.client_id}')">删除</button>`;
        list.appendChild(div);
      }
    });
}

async function refreshAllClientSelects() {
  const r = await fetch(ISSUER + '/api/clients');
  const d = await r.json();
  const acSel = document.getElementById('ac-client');
  const ccSel = document.getElementById('cc-client');
  const quickSel = document.getElementById('td-quick-client');

  function fillSelect(sel, filterFn) {
    const selVal = sel.value;
    sel.innerHTML = '';
    const def = document.createElement('option');
    def.value = '';
    def.textContent = '-- 请选择 --';
    sel.appendChild(def);
    for (const c of d.test_clients) {
      if (!filterFn(c)) continue;
      const o = document.createElement('option');
      o.value = c.client_id;
      o.dataset.secret = c.client_secret || '';
      o.dataset.type = c.type;
      o.dataset.scope = c.scope;
      o.textContent = `${c.name} (${c.type})`;
      sel.appendChild(o);
    }
    if ([...sel.options].some((o) => o.value === selVal)) sel.value = selVal;
  }

  fillSelect(acSel, (c) => c.grant_types.includes('authorization_code'));
  fillSelect(ccSel, (c) => c.grant_types.includes('client_credentials'));

  quickSel.innerHTML = '';
  const def2 = document.createElement('option');
  def2.value = '';
  def2.textContent = '-- 选择客户端自动填入认证信息 --';
  quickSel.appendChild(def2);
  for (const c of d.test_clients) {
    const o = document.createElement('option');
    o.value = c.client_id + ':' + (c.client_secret || '');
    o.textContent = c.name;
    quickSel.appendChild(o);
  }
}

function refreshGrants() {
  fetch(ISSUER + '/api/grants')
    .then((r) => r.json())
    .then((arr) => {
      const tbody = document.getElementById('grants-tbody');
      tbody.innerHTML = '';
      if (!arr.length) {
        tbody.innerHTML = `<tr><td colspan="7" style="padding:20px;border:1px solid #334155;text-align:center;color:#94a3b8">暂无授权记录，完成一次授权码流程后会出现。</td></tr>`;
        return;
      }
      for (const g of arr) {
        const tr = document.createElement('tr');
        tr.innerHTML =
          `<td style="padding:10px;border:1px solid #334155">${g.user_name}</td>` +
          `<td style="padding:10px;border:1px solid #334155">${g.client_name}</td>` +
          `<td style="padding:10px;border:1px solid #334155;font-size:12px;color:#a5b4fc">${g.scope}</td>` +
          `<td style="padding:10px;border:1px solid #334155;font-size:12px;color:#94a3b8">${g.created_at}</td>` +
          `<td style="padding:10px;border:1px solid #334155;text-align:center">${g.authorization_count}</td>` +
          `<td style="padding:10px;border:1px solid #334155">${g.revoked
            ? '<span class="status-badge status-inactive">已撤销</span>'
            : '<span class="status-badge status-active">● 有效</span>'}</td>` +
          `<td style="padding:10px;border:1px solid #334155">${g.revoked
            ? '<span style="color:#64748b;font-size:12px">' + (g.revoked_at || '') + '</span>'
            : `<button class="btn btn-danger btn-sm" onclick="revokeGrant('${g.user_id}','${g.client_id}')">撤销授权</button>`}</td>`;
        tbody.appendChild(tr);
      }
    });
}

function revokeGrant(userId, clientId) {
  if (!confirm('确认撤销该用户对该客户端的授权？该用户的所有 refresh_token 将被吊销。')) return;
  fetch(ISSUER + '/api/grants/revoke', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ user_id: userId, client_id: clientId }),
  })
    .then((r) => r.json())
    .then((d) => {
      alert(`撤销完成。找到授权:${d.found}，吊销 refresh_token 数:${d.tokens_revoked}`);
      refreshGrants();
    });
}

document.addEventListener('DOMContentLoaded', () => {
  refreshClients();
  refreshGrants();
});

</script>
</body>
</html>
