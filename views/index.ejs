  <div class="grid-2">
    <div class="card">
      <h3>创建新客户端</h3>
      <div class="form-group">
        <label>客户端名称 *</label>
        <input type="text" id="cm-name" placeholder="例如: My Demo App">
      </div>
      <div class="form-group">
        <label>客户端类型</label>
        <select id="cm-type">
          <option value="confidential">confidential (需 client_secret)</option>
