        </select>
      </div>
      <div class="form-group">
        <label>Grant Types (空格分隔，authorization_code / client_credentials / refresh_token / implicit)</label>
        <input type="text" id="cm-grants" value="authorization_code refresh_token">
      </div>
      <div class="form-group">
        <label>Response Types (空格分隔，通常填 code)</label>
        <input type="text" id="cm-responses" value="code">
      </div>
      <div class="form-group">
        <label>允许的 Scope (空格分隔)</label>
        <input type="text" id="cm-scope" value="openid profile email read write">
      </div>
      <div class="form-group">
        <label>Redirect URIs (换行分隔，authorization_code 必填)</label>
        <textarea id="cm-redirects" style="min-height:80px">http://localhost:3000/test/callback</textarea>
