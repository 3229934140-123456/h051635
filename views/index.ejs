          <tr><td style="padding:10px;border:1px solid #334155;color:#a5b4fc">sub</td><td style="padding:10px;border:1px solid #334155;color:#94a3b8">openid</td><td style="padding:10px;border:1px solid #334155;color:#e2e8f0">用户唯一标识（始终返回）</td></tr>
          <tr><td style="padding:10px;border:1px solid #334155;color:#a5b4fc">name / given_name / family_name</td><td style="padding:10px;border:1px solid #334155;color:#94a3b8">profile</td><td style="padding:10px;border:1px solid #334155;color:#e2e8f0">姓名相关</td></tr>
          <tr><td style="padding:10px;border:1px solid #334155;color:#a5b4fc">email / email_verified</td><td style="padding:10px;border:1px solid #334155;color:#94a3b8">email</td><td style="padding:10px;border:1px solid #334155;color:#e2e8f0">邮箱信息</td></tr>
          <tr><td style="padding:10px;border:1px solid #334155;color:#a5b4fc">preferred_username</td><td style="padding:10px;border:1px solid #334155;color:#94a3b8">profile</td><td style="padding:10px;border:1px solid #334155;color:#e2e8f0">登录名</td></tr>
          <tr><td style="padding:10px;border:1px solid #334155;color:#a5b4fc">updated_at</td><td style="padding:10px;border:1px solid #334155;color:#94a3b8">profile</td><td style="padding:10px;border:1px solid #334155;color:#e2e8f0">资料更新时间戳</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <h3>Scope 效果快速演示（自动生成 token 对比）</h3>
    <div class="warn-box">选择下面任一场景，系统会用 Test Web App + 用户凭证签一个带对应 scope 的 token，再调 UserInfo 看 claims 差异。</div>
    <div class="row" style="gap:8px">
      <button class="btn btn-outline btn-sm" onclick="demoUserinfoScopes('openid')">仅 openid</button>
      <button class="btn btn-outline btn-sm" onclick="demoUserinfoScopes('openid profile')">openid + profile</button>
      <button class="btn btn-outline btn-sm" onclick="demoUserinfoScopes('openid email')">openid + email</button>
      <button class="btn btn-outline btn-sm" onclick="demoUserinfoScopes('openid profile email')">全量 openid/profile/email</button>
    </div>
    <div id="ui-demo-result" class="result-box" style="margin-top:16px;min-height:100px"></div>
  </div>
</div>

<!-- ========== 客户端管理 ========== -->
