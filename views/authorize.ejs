<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>授权确认 - OAuth2 Server</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .container {
      background: white;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      max-width: 500px;
      width: 100%;
      overflow: hidden;
    }
    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      padding: 30px;
      text-align: center;
      color: white;
    }
    .header h1 { font-size: 24px; margin-bottom: 8px; }
    .header p { opacity: 0.9; font-size: 14px; }
    .content { padding: 30px; }
    .user-info {
      display: flex;
      align-items: center;
      padding: 16px;
      background: #f8f9fa;
      border-radius: 8px;
      margin-bottom: 24px;
    }
    .avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      font-weight: 600;
      margin-right: 12px;
    }
    .user-details .name { font-weight: 600; color: #1a1a2e; }
    .user-details .username { font-size: 14px; color: #666; }
    .client-info {
      text-align: center;
      margin-bottom: 24px;
    }
    .client-info h2 {
      font-size: 18px;
      color: #1a1a2e;
      margin-bottom: 8px;
    }
    .client-info p {
      color: #666;
      font-size: 14px;
    }
    .scopes-title {
      font-size: 16px;
      font-weight: 600;
      color: #1a1a2e;
      margin-bottom: 16px;
    }
    .scopes-list {
      list-style: none;
      margin-bottom: 30px;
    }
    .scope-item {
      display: flex;
      align-items: center;
      padding: 12px 16px;
      background: #f8f9fa;
      border-radius: 8px;
      margin-bottom: 8px;
    }
    .scope-item:last-child { margin-bottom: 0; }
    .scope-icon {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #e3f2fd;
      color: #1976d2;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 12px;
      font-size: 14px;
    }
    .scope-name {
      font-weight: 600;
      color: #1a1a2e;
      font-size: 14px;
    }
    .scope-desc {
      font-size: 13px;
      color: #666;
    }
    .actions {
      display: flex;
      gap: 12px;
    }
    .btn {
      flex: 1;
      padding: 14px;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-cancel {
      background: #f5f5f5;
      color: #666;
    }
    .btn-cancel:hover { background: #e0e0e0; }
    .btn-allow {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }
    .btn-allow:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>OAuth2 授权请求</h1>
      <p>请确认是否授权以下访问</p>
    </div>
    <div class="content">
      <div class="user-info">
        <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <div class="user-details">
          <div class="name"><%= user.name %></div>
          <div class="username"><%= user.username %></div>
        </div>
      </div>
      <div class="client-info">
        <h2><%= client.name %></h2>
        <p>请求获得以下权限：</p>
      </div>
      <div class="scopes-title">请求的权限范围</div>
      <ul class="scopes-list">
        <% scopes.forEach(function(s) { %>
          <li class="scope-item">
            <div class="scope-icon">&#10003;</div>
            <div>
              <div class="scope-name"><%= s.scope %></div>
              <div class="scope-desc"><%= s.description %></div>
            </div>
          </li>
        <% }); %>
      </ul>
      <form method="POST" action="/authorize">
        <input type="hidden" name="response_type" value="<%= responseType %>">
        <input type="hidden" name="client_id" value="<%= client.clientId %>">
        <input type="hidden" name="redirect_uri" value="<%= redirectUri %>">
        <input type="hidden" name="scope" value="<%= finalScopes %>">
        <% if (state) { %><input type="hidden" name="state" value="<%= state %>"><% } %>
        <% if (nonce) { %><input type="hidden" name="nonce" value="<%= nonce %>"><% } %>
        <% if (codeChallenge) { %><input type="hidden" name="code_challenge" value="<%= codeChallenge %>"><% } %>
        <% if (codeChallengeMethod) { %><input type="hidden" name="code_challenge_method" value="<%= codeChallengeMethod %>"><% } %>
        <% if (responseMode) { %><input type="hidden" name="response_mode" value="<%= responseMode %>"><% } %>
        <div class="actions">
          <button type="submit" name="action" value="deny" class="btn btn-cancel">拒绝</button>
          <button type="submit" name="action" value="allow" class="btn btn-allow">授权</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
